# tfg.conf — Terraform Graphical Manager Configuration
# Copy this file to config/tfg.conf and edit as needed.
# Run the app with:  tgm start   or   python run.py

# ──────────────────────────────────────────────────────────────
# Workspaces
# ──────────────────────────────────────────────────────────────
[workspaces]

# Absolute (or relative) path to the root directory that contains
# your Terraform repositories / workspaces.
# Any subdirectory with at least one .tf file is treated as a
# workspace and will appear in the sidebar tree.
repos_root = /data/terraform/repos

# ──────────────────────────────────────────────────────────────
# UI
# ──────────────────────────────────────────────────────────────
[ui]

# Display name shown in the browser tab and sidebar header.
site_name = Terraform Graphical Manager

# URL used for the "View on GitHub" link in the sidebar.
repo_url = https://github.com/eandresr/terraform-graphical-manager

# UI theme name (currently only: terraform-cloud)
theme = terraform-cloud

# ──────────────────────────────────────────────────────────────
# Execution
# ──────────────────────────────────────────────────────────────
[execution]

# Maximum number of Terraform operations that can run in parallel.
max_concurrent = 3

# ──────────────────────────────────────────────────────────────
# Terraform versions
# ──────────────────────────────────────────────────────────────
[terraform]

# Optional: absolute path to a folder containing versioned Terraform
# binaries.  Each sub-folder should be named after the version and
# contain a 'terraform' executable, e.g.:
#   /opt/terraform-versions/
#   ├── 1.6.0/terraform
#   └── 1.7.5/terraform
# Leave blank to use only the system Terraform on PATH.
versions_folder =

# Default version used for workspaces without an explicit pin.
# Set to a version string (e.g. 1.7.5) or leave as 'system'.
default_version = system

# ──────────────────────────────────────────────────────────────
# Security (portal lock)
# ──────────────────────────────────────────────────────────────
[security]

# PBKDF2 hash of the portal lock password.
# Do NOT set this manually — use the Settings UI to set or change
# the password; it will be hashed and stored here automatically.
# Leave blank to run without authentication (default).
password_hash =
